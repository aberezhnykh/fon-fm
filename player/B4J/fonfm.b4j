#Region Project Attributes 
	#MainFormWidth: 520
	#MainFormHeight: 640 
	#PackagerProperty: IconFile = icon.ico
'	#JavaCompilerPath: 8, C:\java\jdk-19.0.2\bin\javac.exe
'	#JavaCompilerPath: 8, C:\java\jdk-17.0.18-full\bin\javac.exe
#End Region

Sub Process_Globals
	Public Const LabelName = "FON.FM" As String
	Public Const VersionName = "1.0.1" As String
	Public Const VersionCode = 1 As Int
	Public Const HostArgument = "host" As String
	Public Const ExitCodeStop = 100 As Int
	Public Const ExitCodeApplyUpdate = 200 As Int
	Public Const ExitCodeRestart = 201 As Int
	Private fx As JFX
	Private mainForm As Form
	Private startedByHost As Boolean
End Sub

Sub AppStart (form1 As Form, args() As String)
	startedByHost = IsStartedByHost(args)
	mainForm = form1
	mainForm.SetWindowSizeLimits(520, 640, fx.PrimaryScreen.MaxX - fx.PrimaryScreen.MinX, fx.PrimaryScreen.MaxY - fx.PrimaryScreen.MinY)
	mainForm.Title = LabelName
	mainForm.Icon = fx.LoadImage(File.DirAssets, "icon.png")
	mainForm.Show
	mainForm.WindowWidth = Max(mainForm.WindowWidth, 520)
	mainForm.WindowHeight = Max(mainForm.WindowHeight, 640)
	Dim pagesManager As B4XPagesManager
	pagesManager.Initialize(mainForm)
End Sub

Private Sub IsStartedByHost(args() As String) As Boolean
	If args = Null Or args.Length = 0 Then Return False
	For Each argValue As String In args
		If argValue = HostArgument Then Return True
	Next
	Return False
End Sub

Public Sub IsHosted As Boolean
	Return startedByHost
End Sub

Public Sub RequestHostStop
	If startedByHost Then
		ExitApplication2(ExitCodeStop)
	Else
		ExitApplication
	End If
End Sub

Public Sub RequestHostRestart
	If startedByHost Then
		ExitApplication2(ExitCodeRestart)
	Else
		ExitApplication
	End If
End Sub

Public Sub RequestHostApplyUpdate
	If startedByHost Then
		ExitApplication2(ExitCodeApplyUpdate)
	Else
		ExitApplication
	End If
End Sub

'Template version: B4J-1.0
#Region Delegates
Sub MainForm_FocusChanged (hasFocus As Boolean)
	B4XPages.Delegate.MainForm_FocusChanged(hasFocus)
End Sub

Sub MainForm_Resize (width As Double, height As Double)
	B4XPages.Delegate.MainForm_Resize(width, height)
End Sub

Sub MainForm_Closed
	B4XPages.MainPage.SaveWindowState
	B4XPages.MainPage.FlushPendingCacheIndexes
	B4XPages.MainPage.CleanupPlaybackTempFiles
	B4XPages.Delegate.MainForm_Closed
End Sub

Sub MainForm_CloseRequest (eventData As Event)
	B4XPages.Delegate.MainForm_CloseRequest(eventData)
	If startedByHost Then
		ExitApplication2(ExitCodeStop)
	End If
End Sub

Public Sub MainForm_IconifiedChanged (iconified As Boolean)
	B4XPages.Delegate.MainForm_IconifiedChanged(iconified)
End Sub
#End Region
